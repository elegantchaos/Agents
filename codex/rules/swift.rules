prefix_rule(pattern=["swift", "build"], decision="allow")
prefix_rule(pattern=["swift", "package", "describe"], decision="allow")
prefix_rule(pattern=["swift", "package", "plugin", "--allow-writing-to-package-directory", "generate-workflow"], decision="allow")
prefix_rule(pattern=["swift", "package", "plugin", "--list"], decision="allow")
prefix_rule(pattern=["swift", "package", "resolve"], decision="allow")
prefix_rule(pattern=["swift", "package", "show-dependencies"], decision="allow")
prefix_rule(pattern=["swift", "package", "update"], decision="allow")
prefix_rule(pattern=["swift", "test"], decision="allow")
