prefix_rule(pattern=["/bin/zsh", "-lc"], decision="allow")
prefix_rule(pattern=["bundle", "outdated"], decision="allow")
prefix_rule(pattern=["bundle", "update", "webrick"], decision="allow")
prefix_rule(pattern=["cat"], decision="allow")
prefix_rule(pattern=["validate-changes"], decision="allow")
prefix_rule(pattern=["validate-target"], decision="allow")
prefix_rule(pattern=["gh", "pr"], decision="allow")
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["pwd"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["which"], decision="allow")
prefix_rule(pattern=["xcodebuild", "-workspace"], decision="allow")