prefix_rule(pattern=[".venv/bin/python"], decision="allow")
prefix_rule(pattern=["brew", "info", "xpkg-git"], decision="allow")
prefix_rule(pattern=["brew", "install", "--HEAD"], decision="allow")
prefix_rule(pattern=["brew", "postinstall", "xpkg-git"], decision="allow")
prefix_rule(pattern=["brew", "reinstall"], decision="allow")
prefix_rule(pattern=["brew", "xpkg", "activate"], decision="allow")
prefix_rule(pattern=["mint", "install", "ReleaseTools"], decision="allow")
prefix_rule(pattern=["rt"], decision="allow")
